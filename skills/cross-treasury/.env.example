# cross-treasury - copy to .env and fill in. NEVER COMMIT THIS FILE.

CROSS_RPC_URL=https://mainnet.crosstoken.io:22001/

# Optional for read-only status. If omitted, pass an address argument.
TREASURY_ADDRESS=

# Required only for writes. Never print or commit.
PRIVATE_KEY=

# Sibling skill root. Defaults to two levels above this repo when installed as
# C:\...\cross-skills\skill-cross-treasury\skills\cross-treasury.
CROSS_SKILLS_ROOT=

# Deterministic policy.
TREASURY_LIQUID_RESERVE_PCT=10
TREASURY_NATIVE_STAKE_PCT=45
TREASURY_AGENT_TOKEN_LP_PCT=45
MIN_GAS_NATIVE_CROSS=5
MAX_TREASURY_ACTION_CROSS=100
CONFIRM_THRESHOLD_CROSS=1

# Optional Forge/GameToken targets.
AGENT_TOKEN_SYMBOL=
AGENT_TOKEN_ADDRESS=
AGENT_LP_SYMBOL=

# Write gate. Keep false unless you are deliberately executing.
CROSS_TREASURY_ENABLE_WRITES=false
